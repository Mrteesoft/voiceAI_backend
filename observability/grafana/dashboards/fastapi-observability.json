{
  "title": "FastAPI Observability",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(app_http_requests_total[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 Request Duration",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(app_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Queue Depth",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "app_message_queue_depth"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Async Jobs By Status",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(app_async_message_jobs_total[5m])) by (status, channel)",
          "legendFormat": "{{channel}} - {{status}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
