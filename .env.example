APP_NAME=AI Assistant Backend MVP
APP_VERSION=0.3.0
APP_ENV=development
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/assistant_db
MODEL_BACKEND=mock
MODEL_NAME=demo-assistant
SYSTEM_PROMPT=You are a helpful backend AI assistant that explains system design clearly.
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/app.log
ECS_LOGGING_ENABLED=true
SLOW_REQUEST_THRESHOLD_MS=300
MODEL_HISTORY_WINDOW_SIZE=12
DEFAULT_HISTORY_LIMIT=50
DEFAULT_DOCUMENT_LIMIT=50
DEFAULT_SEARCH_LIMIT=5
RAG_ENABLED=true
RAG_QUERY_HISTORY_WINDOW=3
RAG_RETRIEVAL_LIMIT=4
RAG_CONTEXT_CHAR_LIMIT=1600
EMBEDDING_BACKEND=hash
EMBEDDING_DIMENSIONS=384
OBSERVABILITY_SERVICE_NAME=ai-assistant-backend
PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PATH=/metrics
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
DATADOG_ENABLED=false
DATADOG_SERVICE=ai-assistant-backend
DATADOG_ENV=development
DATADOG_VERSION=0.3.0
NEW_RELIC_ENABLED=false
NEW_RELIC_CONFIG_FILE=./observability/newrelic/newrelic.ini
NEW_RELIC_ENVIRONMENT=development
